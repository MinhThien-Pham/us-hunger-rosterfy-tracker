{
  "manifest_version": 3,
  "name": "US Hunger Rosterfy Tracker",
  "version": "0.1.0",
  "description": "Track US Hunger Rosterfy opportunities, applications, confirmations, map counts, and calendar exports.",
  "permissions": ["activeTab"],
  "host_permissions": ["https://ushunger.rosterfy.com/*"],
  "action": {
    "default_title": "US Hunger Tracker",
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://ushunger.rosterfy.com/*"],
      "js": ["src/content.js"]
    }
  ]
}
